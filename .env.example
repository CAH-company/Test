# ───────────────────────────────────────────────
# Buddy's Events — Environment Variables
# Copy this file to .env.local and fill in values
# ───────────────────────────────────────────────

# Google Analytics 4 Measurement ID
# Get it from: https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token
# Get it from: https://search.google.com/search-console → Verify ownership → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=

# Contact form endpoint — points to internal API route using Resend
NEXT_PUBLIC_FORM_ENDPOINT=/api/contact

# Resend API key — get it from: https://resend.com → API Keys
# Domain must be verified in Resend dashboard before use
RESEND_API_KEY=

# Comma-separated list of emails that receive form submissions
# Example: marta@buddys-events.pl,kasia@buddys-events.pl
CONTACT_RECIPIENTS=marta@buddys-events.pl,kasia@buddys-events.pl

# ───────────────────────────────────────────────
# Buddy's Events — Environment Variables
# Copy this file to .env.local and fill in values
# ───────────────────────────────────────────────

# Google Analytics 4 Measurement ID
# Get it from: https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token
# Get it from: https://search.google.com/search-console → Verify ownership → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=

# Contact form API endpoint
# Options:
#   - Formspree:   https://formspree.io/f/YOUR_FORM_ID
#   - Web3Forms:   https://api.web3forms.com/submit  (requires access_key in form)
#   - Custom API:  https://your-api.example.com/contact
# If left empty, the form will open the user's mail client as a fallback.
NEXT_PUBLIC_FORM_ENDPOINT=
